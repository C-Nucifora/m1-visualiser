// Synthetic M1 script fixture for m1-visualiser tests.
// Reads Root.Engine.Speed and the MaxSpeed parameter, writes Root.Engine.Limited.
// The data-flow pass extracts these reads/writes into DataFlow edges
// (reads -> Limiter, Limiter -> Limited).
local s = Root.Engine.Speed;
local m = Root.Engine.MaxSpeed.Value;
Root.Engine.Limited = s > m ? m : s;
